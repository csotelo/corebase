# Django
DJANGO_ENV=development
DJANGO_SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=multitenant_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=multitenant_mongo

# Celery — Redis is broker and result backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Default admin (created on first migrate — change immediately)
DEFAULT_ADMIN_EMAIL=admin@corebase.local
DEFAULT_ADMIN_PASSWORD=P4ssw0rd!

# Email
# Dev: Mailpit corre en docker-compose (UI en http://localhost:8025) — no configurar aquí
# Prod — ejemplos por proveedor:
#   Resend:    EMAIL_HOST=smtp.resend.com  EMAIL_HOST_USER=resend  EMAIL_HOST_PASSWORD=re_xxxx
#   SendGrid:  EMAIL_HOST=smtp.sendgrid.net  EMAIL_HOST_USER=apikey  EMAIL_HOST_PASSWORD=SG.xxxx
#   AWS SES:   EMAIL_HOST=email-smtp.us-east-1.amazonaws.com  EMAIL_PORT=587
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# Módulo sunat_clavesol — cifrado de credenciales SOL at-rest
# Genera una con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SUNAT_FIELD_ENCRYPTION_KEY=

# Sentry (Production)
SENTRY_DSN=

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# FastAPI
FASTAPI_SECRET_KEY=your-fastapi-secret-key
FASTAPI_ALGORITHM=HS256
